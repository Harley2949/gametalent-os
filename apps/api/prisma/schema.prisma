  // Game industry specific
  isGamingSpecific Boolean @default(false)
  popularity   Int      @default(0) // How often this tag appears

  // Related skills
  relatedTags String[]

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("skill_tags")
}

model DeduplicationLog {
  id          String   @id @default(cuid())
  candidateId String

  // Match information
  matchedCandidateId String?
  matchScore    Float
  matchReason   String[] // Why these were considered duplicates

  // Action taken
  action       String // MERGED, SKIPPED, FLAGGED
  performedBy  String?

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([candidateId])
  @@map("deduplication_logs")
}


// ============================================
// Module: permission.prisma
// ============================================

// ============================================
// Permissions & Roles Module
// ============================================

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  resource    String   // e.g., "candidates", "jobs"
  action      String   // e.g., "read", "write", "delete"
  conditions  Json?    // Additional conditions

  roles       RolePermission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}

model RolePermission {
  id          String   @id @default(cuid())
  roleId      String
  permissionId String

  // Custom conditions for this role
  conditions  Json?

  role        Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission  Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted

  permissions RolePermission[]
  users       UserRoleMapping[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model UserRoleMapping {
  id          String   @id @default(cuid())
  userId      String
  roleId      String

  // Additional constraints
  constraints Json?    // e.g., department restrictions

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role_mappings")
}


// ============================================
// Module: portal.prisma
// ============================================

// ============================================
// Candidate Portal Module
// ============================================

model CandidatePortal {
  id          String   @id @default(cuid())
  candidateId String   @unique
  accessToken String   @unique // Token for portal access
  tokenExpiry DateTime?

  // Portal access tracking
  lastAccessAt DateTime?
  accessCount  Int      @default(0)

  // Preferences
  language    String   @default("zh-CN")
  timezone    String?

  isActive    Boolean  @default(true)

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accessToken])
  @@map("candidate_portals")
}

model InternalNote {
  id          String   @id @default(cuid())
  candidateId String?
  applicationId String?

  // Strictly internal - never visible to candidates
  title       String
  content     String   @db.Text

  // Classification
  category    String   // e.g., "salary_negotiation", "culture_concern", "background_check"
  sensitivity  String   @default("internal") // internal, confidential, restricted

  // Access control
  createdBy   String
  visibleTo   String[] // Role IDs that can see this note
  creator     User     @relation("NoteCreator", fields: [createdBy], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([candidateId])
  @@index([applicationId])
  @@map("internal_notes")
}


// ============================================
// Module: resume.prisma
// ============================================

// ============================================
// Resume Management Module
// ============================================

enum ResumeStatus {
  PARSING
  READY
  ERROR
}

model Resume {
  id          String        @id @default(cuid())
  candidateId String
  title       String
  fileName    String
  fileUrl     String
  fileSize    Int
  fileType    String        // e.g., "application/pdf"

  // Parsed data stored as JSONB for flexibility
  rawData     Json?         // Raw extracted text/data
  parsedData  Json?         // Structured parsed data

  // AI Analysis
  skills      String[]      // Extracted skills
  experience  Json?         // Structured experience data
  education   Json?         // Structured education data

  status      ResumeStatus  @default(PARSING)
  isPrimary   Boolean       @default(false)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  parsings    ResumeParsing[]

  @@index([candidateId])
  @@map("resumes")
}


// ============================================
// Module: user.prisma
// ============================================

// ============================================
// User Management Module
// ============================================

enum UserRole {
  ADMIN
  RECRUITER
  INTERVIEWER
  HIRING_MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  password      String
  avatar        String?
  role          UserRole    @default(RECRUITER)
  status        UserStatus  @default(ACTIVE)
  department    String?
  title         String?
  phoneNumber   String?
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  createdJobs   Job[]       @relation("JobCreator")
  assignedJobs  Job[]       @relation("JobAssignee")
  applications  Application[] @relation("ApplicationReviewer")
  interviews    Interview[] @relation("InterviewInterviewer")
  feedback      Feedback[]  @relation("FeedbackAuthor")
  roleMappings  UserRoleMapping[]
  createdNotes  InternalNote[] @relation("NoteCreator")

  @@map("users")
}


// ============================================
// Module: workflow.prisma
// ============================================

// ============================================
// Workflow Management Module
// ============================================

model ProcessTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)

  // Job type this template applies to
  jobTypes    String[] // e.g., ["FULL_TIME", "CONTRACT"]

  nodes       ProcessNode[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("process_templates")
}

model ProcessNode {
  id          String   @id @default(cuid())
  templateId  String?
  name        String
  label       String
  description String?  @db.Text

  // Node configuration
  stage       ApplicationStatus // Which stage this node represents
  order       Int              // Order in the workflow
  isRequired  Boolean  @default(true)

  // Requirements to proceed
  requiredFields String[] // Fields that must be filled before proceeding

  // Auto-advance configuration
  autoAdvance Boolean  @default(false)
  autoAdvanceRule Json? // Rule for auto-advancing

  // Notifications
  notifyCandidate Boolean  @default(false)
  notifyInterviewers Boolean @default(false)
  notificationTemplates Json?

  template    ProcessTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateId])
  @@map("process_nodes")
}

model ProcessRule {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)

  // Rule type
  ruleType    String // AUTO_ADVANCE, TIMEOUT_REMINDER, TIMEOUT_REJECT
  triggerCondition Json // When to trigger

  // Actions
  actions     Json[] // Actions to execute

  // Scope
  appliesToJobs String[] // Job IDs this rule applies to (empty = all)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("process_rules")
}

model ProcessLog {
  id          String   @id @default(cuid())
  applicationId String
  nodeId      String?

  // What changed
  fromStatus  ApplicationStatus
  toStatus    ApplicationStatus

  // Who made the change
  changedBy   String
  changeType  String // MANUAL, AUTO, SYSTEM

  // Additional data
  metadata    Json?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([applicationId])
  @@map("process_logs")
}

