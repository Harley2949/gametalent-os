// ============================================
// Module: application.prisma
// ============================================

// ============================================
// Application Management Module
// ============================================

enum ApplicationStatus {
  APPLIED
  SCREENING
  REVIEWED
  SHORTLISTED
  INTERVIEWING
  INTERVIEW_PASSED  // 面试通过，等待 Offer
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

// Transparency level controls what information is visible to candidates
enum TransparencyLevel {
  STANDARD    // Full visibility
  MINIMAL     // Limited info
  CUSTOM      // Custom rules
}

model Application {
  id                  String             @id @default(cuid())
  jobId               String
  candidateId         String
  status              ApplicationStatus @default(APPLIED)

  // Privacy control - for competitive hiring
  transparencyLevel   TransparencyLevel  @default(STANDARD)
  customVisibility    Json?              // Custom visibility rules

  // Application details
  coverLetter         String?            @db.Text
  source              String?            // Where they applied from
  referralSource      String?            // If referred

  // Screening
  screeningScore      Float?             // AI screening score 0-100
  screeningNotes      String?            @db.Text
  screenedAt          DateTime?
  screenedBy          String?

  // AI Matching
  matchScore          Float?             // Overall match score 0-100
  matchDetails        Json?              // Detailed match breakdown

  // Timeline tracking
  appliedAt           DateTime           @default(now())
  firstResponseAt     DateTime?
  lastContactAt       DateTime?
  closedAt            DateTime?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  job                 Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate           Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reviewer            User?              @relation("ApplicationReviewer", fields: [screenedBy], references: [id])
  interviews          Interview[]
  feedback            Feedback[]
  logs                ProcessLog[]
  offer               Offer?

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
  @@map("applications")
}


// ============================================
// Module: candidate.prisma
// ============================================

// ============================================
// Candidate Management Module
// ============================================

enum CandidateStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  BLACKLISTED
}

enum CandidateSource {
  LINKEDIN
  REFERRAL
  CAREER_PAGE
  AGENCY
  HEADHUNT
  OTHER
}

model Candidate {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  phoneNumber       String?
  avatar            String?
  status            CandidateStatus    @default(ACTIVE)
  source            CandidateSource
  sourceUrl         String?            // Original profile URL

  // Competitor tracking - JSONB field for flexible storage
  // Structure: { companies: [{ companyId, companyName, projects[], relationship, confidence }] }
  competitorMapping Json?

  // Social links
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?

  // Additional info
  location          String?
  currentCompany    String?
  currentTitle      String?
  expectedSalary    String?
  noticePeriod      String?            // e.g., "2 weeks", "1 month"
  yearsOfExperience Int?

  // Notes
  notes             String?
  tags              String[]           // e.g., ["game-design", "unity", "senior"]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  resumes           Resume[]
  applications      Application[]
  feedback          Feedback[]
  portal            CandidatePortal?
  deduplicationLogs DeduplicationLog[]
  salaryRecords     SalaryRecord[]

  @@map("candidates")
}


// ============================================
// Module: feedback.prisma
// ============================================

// ============================================
// Feedback Management Module
// ============================================

enum FeedbackType {
  INTERVIEW
  APPLICATION
  CANDIDATE
  GENERAL
}

model Feedback {
  id              String        @id @default(cuid())
  applicationId   String?
  candidateId     String?
  interviewId     String?
  authorId        String

  type            FeedbackType

  // Privacy control - internal only feedback not shared with candidates
  internalOnly    Boolean       @default(false)

  // Content
  rating          Int?          // 1-5 rating
  pros            String?       @db.Text
  cons            String?       @db.Text
  notes           String        @db.Text

  // Tags for filtering
  tags            String[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  application     Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidate       Candidate?    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author          User          @relation("FeedbackAuthor", fields: [authorId], references: [id])

  @@index([applicationId])
  @@index([candidateId])
  @@index([authorId])
  @@map("feedback")
}


// ============================================
// Module: interview.prisma
// ============================================

// ============================================
// Interview Management Module
// ============================================

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InterviewType {
  PHONE_SCREEN
  VIDEO
  ONSITE
  TECHNICAL
  BEHAVIORAL
  PANEL
  TAKE_HOME
}

enum InterviewStage {
  SCREENING
  FIRST_ROUND
  SECOND_ROUND
  FINAL_ROUND
  TECHNICAL
  CULTURAL
  EXECUTIVE
}

model Interview {
  id              String           @id @default(cuid())
  applicationId   String
  interviewerId   String
  title           String
  description     String?          @db.Text

  status          InterviewStatus  @default(SCHEDULED)
  type            InterviewType
  stage           InterviewStage

  // Scheduling
  scheduledAt     DateTime
  duration        Int              // Duration in minutes
  location        String?          // Meeting link or physical location

  // Evaluation
  score           Int?             // 1-5 rating
  notes           String?          @db.Text
  feedback        Json?            // Structured feedback

  // Follow-up
  nextSteps       String?          @db.Text
  followUpAt      DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewer     User             @relation("InterviewInterviewer", fields: [interviewerId], references: [id])

  @@index([applicationId])
  @@index([interviewerId])
  @@index([scheduledAt])
  @@map("interviews")
}


// ============================================
// Module: job.prisma
// ============================================

// ============================================
// Job Management Module
// ============================================

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Job {
  id                String          @id @default(cuid())
  title             String
  description       String          @db.Text
  requirements      String          @db.Text
  responsibilities  String          @db.Text

  // Job metadata
  status            JobStatus       @default(DRAFT)
  type              JobType         @default(FULL_TIME)
  workMode          WorkMode        @default(ONSITE)
  experienceLevel   ExperienceLevel
  priority          Priority        @default(MEDIUM)

  // Compensation
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String          @default("USD")

  // Location
  location          String?
  remoteRegions     String[]        // For remote jobs

  // Department & Team
  department        String
  team              String?

  // Hiring targets
  targetCompanies   String[]        // Competitor companies to target
  targetSkills      String[]        // Required/preferred skills

  // Applicant tracking
  applicantCount    Int             @default(0)
  interviewCount    Int             @default(0)
  offerCount        Int             @default(0)

  // Dates
  publishedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  createdBy         String
  creator           User            @relation("JobCreator", fields: [createdBy], references: [id])
  assignees         User[]          @relation("JobAssignee")
  applications      Application[]

  @@index([status])
  @@index([department])
  @@index([publishedAt])
  @@map("jobs")
}


// ============================================
// Module: offer.prisma
// ============================================

// ============================================
// Offer & Salary Module
// ============================================

model Offer {
  id          String   @id @default(cuid())
  applicationId String   @unique

  // Salary details
  baseSalary    Int?
  bonus         Int?
  equity        Json?    // Equity package details
  totalComp     Int?

  currency     String   @default("CNY")

  // Offer status
  status       String   // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  sentAt       DateTime?
  acceptedAt   DateTime?
  expiresAt    DateTime?

  // Negotiation
  expectedSalary Int?
  counterOffer  Json?

  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  application  Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@map("offers")
}

model SalaryRecord {
  id          String   @id @default(cuid())
  candidateId String

  // Salary breakdown
  baseSalary    Int
  bonus         Int?
  equity        Int?
  totalComp     Int

  currency     String   @default("CNY")

  // Context
  jobTitle     String
  level        String   // e.g., "Senior", "Lead"
  department   String
  location     String

  // Source
  offerId      String?  // If from actual offer
  source       String   // ACTUAL_OFFER, EXPECTED, MARKET_DATA

  // Metadata
  effectiveDate DateTime
  notes        String?

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())

  @@index([candidateId])
  @@index([jobTitle])
  @@map("salary_records")
}


// ============================================
// Module: parsing.prisma
