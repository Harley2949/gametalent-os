  updatedAt    DateTime @updatedAt

  application  Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@map("offers")
}

model SalaryRecord {
  id          String   @id @default(cuid())
  candidateId String

  // Salary breakdown
