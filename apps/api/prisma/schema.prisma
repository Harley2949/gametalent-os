  currency     String   @default("CNY")

  // Offer status
  status       String   // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  sentAt       DateTime?
  acceptedAt   DateTime?
  expiresAt    DateTime?

  // Negotiation
  expectedSalary Int?
