  READY
  ERROR
}

model Resume {
  id          String        @id @default(cuid())
  candidateId String
  title       String
  fileName    String
  fileUrl     String
  fileSize    Int
  fileType    String        // e.g., "application/pdf"

  // Parsed data stored as JSONB for flexibility
  rawData     Json?         // Raw extracted text/data
  parsedData  Json?         // Structured parsed data

  // 新增字段（兼容性）
  rawText         String?       @db.Text  // 兼容性字段，实际上是 rawData
  errorMessage    String?       @db.Text  // 解析错误信息
  parsedAt        DateTime?               // 解析完成时间
  parserVersion   String?                 // 解析器版本

  // AI Analysis
  skills          String[]      // Extracted skills
  experience      Json?         // Structured experience data
  education       Json?         // Structured education data

  status      ResumeStatus  @default(PARSING)
  isPrimary   Boolean       @default(false)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  parsings    ResumeParsing[]
  extractedSkills ExtractedSkill[]
  projectExperiences ProjectExperience[]

  @@index([candidateId])
  @@map("resumes")
}


// ============================================
// Module: scheduling.prisma
// ============================================

// ============================================
// Smart Interview Scheduling Module
// ============================================

// User availability configuration for scheduling
model UserAvailability {
  id              String   @id @default(cuid())
  userId          String   @unique

  // Working hours configuration
  workDays        Int[]    @default([1, 2, 3, 4, 5]) // Monday=1, Friday=5
  workStartAt     String   @default("09:00") // HH:mm format
  workEndAt       String   @default("18:00")

  // Break times
  breakStartAt    String?  @default("12:00")
  breakEndAt      String?  @default("13:00")

  // Timezone
  timezone        String   @default("Asia/Shanghai")

  // Blackout dates (holidays, vacation, etc.)
  blackoutDates   DateTime[]

  // Minimum booking notice (in hours)
  minNoticeHours  Int      @default(2)

  // Maximum booking window (in days)
  maxBookingDays  Int      @default(30)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relation
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_availabilities")
}

// Calendar integration configuration (Google, Outlook, Feishu, etc.)
model CalendarIntegration {
  id              String   @id @default(cuid())
  userId          String

  provider        String   // GOOGLE, OUTLOOK, FEISHU, DINGTALK
  accessToken     String   @db.Text
  refreshToken    String?  @db.Text

  // Calendar ID to sync from
  calendarId      String

  // Sync settings
  autoSync        Boolean  @default(true)
  priority        Int      @default(0)
  lastSyncAt      DateTime?
  syncError       String?
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relation
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("calendar_integrations")
}

// Interview invitation tracking
model InterviewInvitation {
  id              String   @id @default(cuid())
  interviewId     String   @unique

  // Invitation status
  status          String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, EXPIRED

  // Candidate response
  respondedAt     DateTime?
  declinedReason  String?

  // Invitation metadata
  sentAt          DateTime @default(now())
  expiresAt       DateTime?

  // Reminders sent
  remindersSent   Int      @default(0)
  lastReminderAt  DateTime?

  // Email tracking
  emailSentAt     DateTime?
  emailOpenedAt   DateTime?

  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([status])
  @@map("interview_invitations")
}

// Interview reminder queue
model InterviewReminder {
  id              String   @id @default(cuid())
  interviewId     String

  // Reminder type
  type            String   // BEFORE_24H, BEFORE_1H, NO_SHOW, FOLLOW_UP

  // Scheduled delivery
  scheduledAt     DateTime

  // Delivery status
  status          String   @default("PENDING") // PENDING, SENT, FAILED, CANCELLED

  // Delivery result
  sentAt          DateTime?
  error           String?

  // Retry count
  retryCount      Int      @default(0)

  createdAt       DateTime @default(now())

  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("interview_reminders")
}

// Suggested time slots for interviews (cache)
model SuggestedTimeSlot {
  id              String   @id @default(cuid())
  interviewId     String?

  // For batch scheduling suggestions (without specific interview yet)
  applicationId   String?

  // Time slot details
  suggestedAt     DateTime
  duration        Int
  interviewerIds  String[]

  // Scoring for ranking
  score           Float?
  reasons         String[] // Reasons for this suggestion

  // Status
  status          String   @default("AVAILABLE") // AVAILABLE, TAKEN, EXPIRED

  // Validity
  validUntil      DateTime

  createdAt       DateTime @default(now())

  @@index([interviewId])
  @@index([applicationId])
  @@index([suggestedAt])
  @@map("suggested_time_slots")
}

// Interview availability cache (for faster lookups)
model InterviewAvailability {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime // The date being queried

  // Available slots as JSON array
  // Format: [{ "start": "2024-01-15T10:00:00Z", "end": "2024-01-15T11:00:00Z" }]
  availableSlots  Json

  // Cache metadata
  cachedAt        DateTime @default(now())
  expiresAt       DateTime

  // Relation
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("interview_availabilities")
}


// ============================================
// Module: user.prisma
// ============================================

// ============================================
// User Management Module
// ============================================

enum UserRole {
  ADMIN
  RECRUITER
  INTERVIEWER
  HIRING_MANAGER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  password      String
  avatar        String?
  role          UserRole    @default(RECRUITER)
  status        UserStatus  @default(ACTIVE)
  department    String?
  title         String?
  phoneNumber   String?
  lastLoginAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  createdJobs   Job[]       @relation("JobCreator")
  assignedJobs  Job[]       @relation("JobAssignee")
  applications  Application[] @relation("ApplicationReviewer")
  interviews    Interview[] @relation("InterviewInterviewer")
  feedback      Feedback[]  @relation("FeedbackAuthor")
  roleMappings  UserRoleMapping[]
  createdNotes  InternalNote[] @relation("NoteCreator")
  availability  UserAvailability?
  calendarIntegrations CalendarIntegration[]
  availabilities InterviewAvailability[]

  @@map("users")
}


// ============================================
// Module: work-experience.prisma
// ============================================

// ============================================
// Work Experience Module
// ============================================

model WorkExperience {
  id              String        @id @default(cuid())
  candidateId     String

  // 公司信息
  companyId       String?
  companyName     String        // 冗余存储，即使没有关联公司也能显示
  title           String
  level           String?       // 职级，如"高级"、"资深"
  department      String?       // 部门
  location        String?       // 工作地点

  // 时间
  startDate       DateTime
  endDate         DateTime?
  isCurrent       Boolean       @default(false)

  // 目标公司标记（竞争对手公司）
  isTargetCompany Boolean       @default(false)

  // 详情
  description     String?       @db.Text
  achievements    String?       @db.Text

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  candidate       Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@index([companyId])
  @@index([companyName])
  @@index([isCurrent])
  @@map("work_experiences")
}


// ============================================
// Module: workflow.prisma
// ============================================

// ============================================
// Workflow Management Module
// ============================================

model ProcessTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)

  // Job type this template applies to
  jobTypes    String[] // e.g., ["FULL_TIME", "CONTRACT"]

  nodes       ProcessNode[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("process_templates")
}

model ProcessNode {
  id          String   @id @default(cuid())
  templateId  String?
  name        String
  label       String
  description String?  @db.Text

  // Node configuration
  stage       ApplicationStatus // Which stage this node represents
  order       Int              // Order in the workflow
  isRequired  Boolean  @default(true)

  // Requirements to proceed
  requiredFields String[] // Fields that must be filled before proceeding

  // Auto-advance configuration
  autoAdvance Boolean  @default(false)
  autoAdvanceRule Json? // Rule for auto-advancing

  // Notifications
  notifyCandidate Boolean  @default(false)
  notifyInterviewers Boolean @default(false)
  notificationTemplates Json?

  template    ProcessTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([templateId])
  @@map("process_nodes")
}

model ProcessRule {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)

  // Rule type
  ruleType    String // AUTO_ADVANCE, TIMEOUT_REMINDER, TIMEOUT_REJECT
  triggerCondition Json // When to trigger

  // Actions
  actions     Json[] // Actions to execute

  // Scope
  appliesToJobs String[] // Job IDs this rule applies to (empty = all)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("process_rules")
}

model ProcessLog {
  id          String   @id @default(cuid())
  applicationId String
  nodeId      String?

  // What changed
  fromStatus  ApplicationStatus
  toStatus    ApplicationStatus

  // Who made the change
  changedBy   String
  changeType  String // MANUAL, AUTO, SYSTEM

  // Additional data
  metadata    Json?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([applicationId])
  @@map("process_logs")
}

