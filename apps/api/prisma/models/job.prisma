// ============================================
// Job Management Module
// ============================================

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum ExperienceLevel {
  ENTRY
  MID
  SENIOR
  LEAD
  PRINCIPAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Job {
  id                String          @id @default(cuid())
  title             String
  description       String          @db.Text
  requirements      String          @db.Text
  responsibilities  String          @db.Text

  // Job metadata
  status            JobStatus       @default(DRAFT)
  type              JobType         @default(FULL_TIME)
  workMode          WorkMode        @default(ONSITE)
  experienceLevel   ExperienceLevel
  priority          Priority        @default(MEDIUM)

  // Compensation
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String          @default("USD")

  // Location
  location          String?
  remoteRegions     String[]        // For remote jobs

  // Department & Team
  department        String
  team              String?

  // Hiring targets
  targetCompanies   String[]        // Competitor companies to target
  targetSkills      String[]        // Required/preferred skills
  matchWeights      Json?          // 匹配权重配置

  // Applicant tracking
  applicantCount    Int             @default(0)
  interviewCount    Int             @default(0)
  offerCount        Int             @default(0)

  // Dates
  publishedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  createdBy         String
  creator           User            @relation("JobCreator", fields: [createdBy], references: [id])
  assignees         User[]          @relation("JobAssignee")
  applications      Application[]
  jobSkills         JobSkill[]
  jobMatches        JobMatch[]

  @@index([status])
  @@index([department])
  @@index([publishedAt])
  @@map("jobs")
}

// ============================================
// Job Skills Module
// ============================================

enum SkillCategory {
  PROGRAMMING
  DESIGN
  ART
  AUDIO
  PRODUCTION
  TOOLS
  SOFT_SKILLS
  OTHER
}

enum SkillImportance {
  REQUIRED
  PREFERRED
  BONUS
}

enum SkillProficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
  MASTER
}

model JobSkill {
  id              String            @id @default(cuid())
  jobId           String

  name            String
  category        SkillCategory
  importance      SkillImportance   @default(PREFERRED)
  minProficiency  SkillProficiency?
  minYears        Int?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([category])
  @@index([importance])
  @@map("job_skills")
}
