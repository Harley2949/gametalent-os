// ============================================
// Company Management Module
// ============================================

model Company {
  id          String        @id @default(cuid())
  name        String        @unique
  nameEn      String?       @unique
  shortName   String?
  aliases     String[]      // 别名列表，用于模糊匹配

  // 公司分类
  type        CompanyType?
  scale       CompanyScale?
  country     String?
  city        String?

  // 竞争对手标记
  isCompetitor Boolean      @default(false)
  isActive    Boolean       @default(true)

  // 游戏行业特有
  gameGenres  String[]      // 擅长的游戏类型
  platforms   String[]      // 擅长的平台

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  workExperiences WorkExperience[]

  @@index([name])
  @@index([isCompetitor])
  @@index([type])
  @@map("companies")
}
