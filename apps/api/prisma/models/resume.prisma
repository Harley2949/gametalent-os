// ============================================
// Resume Management Module
// ============================================

enum ResumeStatus {
  PARSING
  READY
  ERROR
}

model Resume {
  id          String        @id @default(cuid())
  candidateId String
  title       String
  fileName    String
  fileUrl     String
  fileSize    Int
  fileType    String        // e.g., "application/pdf"

  // Parsed data stored as JSONB for flexibility
  rawData     Json?         // Raw extracted text/data
  parsedData  Json?         // Structured parsed data

  // 新增字段（兼容性）
  rawText         String?       @db.Text  // 兼容性字段，实际上是 rawData
  errorMessage    String?       @db.Text  // 解析错误信息
  parsedAt        DateTime?               // 解析完成时间
  parserVersion   String?                 // 解析器版本

  // AI Analysis
  skills          String[]      // Extracted skills
  experience      Json?         // Structured experience data
  education       Json?         // Structured education data

  status      ResumeStatus  @default(PARSING)
  isPrimary   Boolean       @default(false)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  parsings    ResumeParsing[]
  extractedSkills ExtractedSkill[]
  projectExperiences ProjectExperience[]

  @@index([candidateId])
  @@map("resumes")
}
