// ============================================
// Candidate Management Module
// ============================================

enum CandidateStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  BLACKLISTED
}

enum CandidateSource {
  LINKEDIN
  REFERRAL
  CAREER_PAGE
  AGENCY
  HEADHUNT
  UPLOAD
  OTHER
}

enum CandidateStage {
  INITIAL_SCREENING  // 初筛
  INTERVIEW          // 面试
  OFFER              // Offer
  ONBOARDING         // 入职
  HIRED              // 已入职
  REJECTED           // 已拒绝
}

model Candidate {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String
  phoneNumber       String?
  avatar            String?
  status            CandidateStatus    @default(ACTIVE)
  stage             CandidateStage     @default(INITIAL_SCREENING)
  source            CandidateSource
  sourceUrl         String?            // Original profile URL

  // Competitor tracking - JSONB field for flexible storage
  // Structure: { companies: [{ companyId, companyName, projects[], relationship, confidence }] }
  competitorMapping Json?

  // Social links
  linkedinUrl       String?
  githubUrl         String?
  portfolioUrl      String?

  // Additional info
  location          String?
  currentCompany    String?
  currentTitle      String?
  expectedSalary    String?
  noticePeriod      String?            // e.g., "2 weeks", "1 month"
  yearsOfExperience Int?

  // 新增字段
  currentCompanyId    String?
  educationLevel      EducationLevel?
  school              String?
  schoolType          SchoolType?
  major               String?
  graduationYear      Int?
  isOverseasEducation Boolean?
  isCurrentlyEmployed Boolean?

  // Notes
  notes             String?
  tags              String[]           // e.g., ["game-design", "unity", "senior"]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  resumes           Resume[]
  applications      Application[]
  feedback          Feedback[]
  portal            CandidatePortal?
  deduplicationLogs DeduplicationLog[]
  salaryRecords     SalaryRecord[]
  educations        Education[]
  workExperiences   WorkExperience[]
  jobMatches        JobMatch[]

  @@map("candidates")
}
