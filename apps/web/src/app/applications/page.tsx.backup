const MOCK_CANDIDATES = MOCK_APPLICATIONS.map(app => app.candidate);
const MOCK_JOBS = [
  { id: 'job_001', title: 'Unity 高级开发工程师' },
  { id: 'job_002', title: '技术美术（TA）' },
  { id: 'job_003', title: '游戏服务器开发工程师' },
];

export default function ApplicationsPage() {
  const router = useRouter();
  const searchParams = useSearchParams();
  const toast = useToast();
  const [viewMode, setViewMode] = useState<ViewMode>('kanban');
  const [search, setSearch] = useState('');
  const [statusFilter, setStatusFilter] = useState<string>('');
  const [jobFilter, setJobFilter] = useState<string>('');

  // 🎯 直接使用 Mock 数据初始化
  const [applications, setApplications] = useState<Application[]>(MOCK_APPLICATIONS);

  // 🔄 根据URL参数筛选数据
  useEffect(() => {
    const filter = searchParams.get('filter');
    const status = searchParams.get('status');

    console.log('🎯 URL参数变化:', { filter, status });

    let filtered = MOCK_APPLICATIONS;

    // 根据filter参数筛选
    if (filter === 'all') {
      filtered = MOCK_APPLICATIONS; // 显示所有
      console.log('✅ 筛选：显示所有记录', filtered.length);
    } else if (filter === 'today') {
      // 筛选今日新增（显示所有APPLIED状态的记录，模拟新申请）
      filtered = MOCK_APPLICATIONS.filter(app => app.status === 'APPLIED');
      console.log('✅ 筛选：今日新增（APPLIED状态）', filtered.length);
    }

    // 根据status参数筛选
    if (status) {
      filtered = filtered.filter(app => app.status === status);
      console.log('✅ 筛选：状态 =', status, '数量:', filtered.length);
    }

    console.log('📊 最终筛选结果数量:', filtered.length);
    console.log('📋 筛选后的记录:', filtered.map(app => `${app.id} - ${app.status}`));

    setApplications(filtered);

    // 同时更新看板数据
    const newKanbanData: Record<string, Application[]> = {
      APPLIED: filtered.filter(app => app.status === 'APPLIED'),
      SCREENING: filtered.filter(app => app.status === 'SCREENING'),
      REVIEWED: filtered.filter(app => app.status === 'REVIEWED'),
      SHORTLISTED: filtered.filter(app => app.status === 'SHORTLISTED'),
      INTERVIEWING: filtered.filter(app => app.status === 'INTERVIEWING'),
      INTERVIEW_PASSED: filtered.filter(app => app.status === 'INTERVIEW_PASSED'),
      OFFERED: filtered.filter(app => app.status === 'OFFERED'),
      HIRED: filtered.filter(app => app.status === 'HIRED'),
      REJECTED: filtered.filter(app => app.status === 'REJECTED'),
      WITHDRAWN: filtered.filter(app => app.status === 'WITHDRAWN'),
    };
    setKanbanData(newKanbanData);

    console.log('🔄 看板数据已更新，各列数量:',
      Object.entries(newKanbanData)
        .filter(([_, apps]) => apps.length > 0)
        .map(([status, apps]) => `${status}: ${apps.length}`)
    );
  }, [searchParams]);
  const [kanbanData, setKanbanData] = useState<Record<string, Application[]>>({
    APPLIED: MOCK_APPLICATIONS.filter(app => app.status === 'APPLIED'),
    SCREENING: MOCK_APPLICATIONS.filter(app => app.status === 'SCREENING'),
    REVIEWED: MOCK_APPLICATIONS.filter(app => app.status === 'REVIEWED'),
    SHORTLISTED: MOCK_APPLICATIONS.filter(app => app.status === 'SHORTLISTED'),
    INTERVIEWING: MOCK_APPLICATIONS.filter(app => app.status === 'INTERVIEWING'),
    INTERVIEW_PASSED: MOCK_APPLICATIONS.filter(app => app.status === 'INTERVIEW_PASSED'),
    OFFERED: MOCK_APPLICATIONS.filter(app => app.status === 'OFFERED'),
    HIRED: MOCK_APPLICATIONS.filter(app => app.status === 'HIRED'),
    REJECTED: MOCK_APPLICATIONS.filter(app => app.status === 'REJECTED'),
    WITHDRAWN: MOCK_APPLICATIONS.filter(app => app.status === 'WITHDRAWN'),
  });
  const [stats, setStats] = useState<ApplicationStats>(MOCK_STATS);
  const [candidates, setCandidates] = useState<any[]>(MOCK_CANDIDATES);
  const [jobs, setJobs] = useState<any[]>(MOCK_JOBS);

  // 拖拽状态 - 增强的原生 HTML5 实现
  const [draggedApplication, setDraggedApplication] = useState<Application | null>(null);
  const [dragOverStatus, setDragOverStatus] = useState<string | null>(null);
  const [updatingStatus, setUpdatingStatus] = useState<string | null>(null);
  const [dragPosition, setDragPosition] = useState<{ x: number; y: number } | null>(null);

  // 🔧 使用 ref 存储最新状态，避免闭包问题
  const draggedAppRef = useRef<Application | null>(null);
  const kanbanDataRef = useRef<Record<string, Application[]>>({}); // 🔧 初始化为空对象
  const applicationsRef = useRef<Application[]>([]); // 🔧 初始化为空数组

  // 🔧 更新 ref 当状态变化时
  useEffect(() => {
    draggedAppRef.current = draggedApplication;
    console.log('🔄 [更新 draggedAppRef]', { id: draggedApplication?.id });
  }, [draggedApplication]);

  useEffect(() => {
    kanbanDataRef.current = kanbanData;
    console.log('🔄 [更新 kanbanDataRef]', {
      columns: Object.keys(kanbanData).length,
      totalApps: Object.values(kanbanData).flat().length
    });
  }, [kanbanData]);

  useEffect(() => {
    applicationsRef.current = applications;
    console.log('🔄 [更新 applicationsRef]', { count: applications.length });
  }, [applications]);

  // 🎯 全局拖拽事件监听 - 确保捕获所有拖拽事件
  useEffect(() => {
    const handleGlobalDragOver = (e: DragEvent) => {
      e.preventDefault();
      e.dataTransfer!.dropEffect = 'move';

      // 查找最近的列容器
      const column = (e.target as HTMLElement).closest('[data-column-status]');

      console.log('🔍 [拖拽经过调试]', {
        target: (e.target as HTMLElement).tagName,
        hasColumn: !!column,
        columnStatus: column?.getAttribute('data-column-status'),
        clientX: e.clientX,
        clientY: e.clientY
      });

      if (column) {
        const status = column.getAttribute('data-column-status');
        if (status) {
          console.log('✅ [找到目标列]', { status });
          setDragOverStatus(status);
          setDragPosition({ x: e.clientX, y: e.clientY });
        }
      } else {
        console.log('❌ [未找到列容器]');
        setDragOverStatus(null);
      }
    };

    const handleGlobalDrop = async (e: DragEvent) => {
      e.preventDefault();

      const column = (e.target as HTMLElement).closest('[data-column-status]');
      const currentDraggedApp = draggedAppRef.current;

      console.log('🎯 [拖拽放置调试]', {
        hasColumn: !!column,
        columnStatus: column?.getAttribute('data-column-status'),
        hasDraggedApp: !!currentDraggedApp,
        draggedAppId: currentDraggedApp?.id,
        dataTransferId: (e as any).dataTransfer?.getData('applicationId')
      });

      if (column && currentDraggedApp) {
        const newStatus = column.getAttribute('data-column-status') as ApplicationStatus;
        const applicationId = (e as any).dataTransfer?.getData('applicationId') || currentDraggedApp.id;

        console.log('🎯 [准备更新状态]', {
          applicationId,
          oldStatus: currentDraggedApp.status,
          newStatus,
          areDifferent: currentDraggedApp.status !== newStatus
        });

        setDragOverStatus(null);

        if (applicationId && currentDraggedApp.status !== newStatus) {
          const token = localStorage.getItem('auth_token');
          if (!token) {
            console.error('❌ [未登录]');
            toast.error('❌ 请先登录后再进行操作');
            setDraggedApplication(null);
            draggedAppRef.current = null;
            setDragPosition(null);
            return;
          }

          try {
            console.log('🔄 [开始API调用]');
            setUpdatingStatus(applicationId);

            // 调用 API 更新状态
            await updateApplicationStatus(applicationId, newStatus);

            // 更新本地状态
            const updatedApps = applicationsRef.current.map(app =>
              app.id === applicationId ? { ...app, status: newStatus } : app
            );
            setApplications(updatedApps);

            // 更新看板数据
            const newKanbanData = { ...kanbanDataRef.current };
            if (!newKanbanData[currentDraggedApp.status]) {
              newKanbanData[currentDraggedApp.status] = [];
            }
            newKanbanData[currentDraggedApp.status] = newKanbanData[currentDraggedApp.status]
              .filter(app => app.id !== applicationId);

            if (!newKanbanData[newStatus]) {
              newKanbanData[newStatus] = [];
            }
            newKanbanData[newStatus] = [...newKanbanData[newStatus], { ...currentDraggedApp, status: newStatus }];
            setKanbanData(newKanbanData);

            console.log('✅ [状态更新成功]', { applicationId, newStatus });
            toast.success('✅ 状态更新成功');
          } catch (error) {
            console.error('❌ [更新状态失败]', error);
            toast.error('❌ 更新失败，请重试');
          } finally {
            setUpdatingStatus(null);
          }
        } else {
          console.log('⚠️ [状态未变化或applicationId为空]');
        }
      } else {
        console.log('❌ [缺少列或拖拽应用]');
      }

      setDraggedApplication(null);
      draggedAppRef.current = null;
      setDragPosition(null);
    };

    const handleGlobalDragEnd = () => {
      console.log('✅ [全局拖拽结束]');
      setDragOverStatus(null);
      setDraggedApplication(null);
      setDragPosition(null);
    };

    // 添加全局事件监听
    console.log('🔧 [注册全局拖拽事件监听器]');
    document.addEventListener('dragover', handleGlobalDragOver);
    document.addEventListener('drop', handleGlobalDrop);
    document.addEventListener('dragend', handleGlobalDragEnd);

    return () => {
      console.log('🔧 [移除全局拖拽事件监听器]');
      document.removeEventListener('dragover', handleGlobalDragOver);
      document.removeEventListener('drop', handleGlobalDrop);
      document.removeEventListener('dragend', handleGlobalDragEnd);
    };
  }, []); // 🔧 空依赖数组，只在挂载时运行一次

  const getCandidateName = (candidateId: string) => {
    const candidate = candidates.find((c) => c.id === candidateId);
    return candidate?.name || '未知';
  };

  const getCandidateCompany = (candidateId: string) => {
    const candidate = candidates.find((c) => c.id === candidateId);
    return candidate?.currentCompany || '';
  };

  const getJobTitle = (jobId: string) => {
    const job = jobs.find((j) => j.id === jobId);
    return job?.title || '未知';
  };

  const handleSearch = (value: string) => {
    setSearch(value);
  };

  const handleStatusFilter = (value: string) => {
    setStatusFilter(value);
  };

  const handleJobFilter = (value: string) => {
    setJobFilter(value);
  };

  const hasActiveFilters = statusFilter || jobFilter || search;

  const clearFilters = () => {
    setStatusFilter('');
    setJobFilter('');
    setSearch('');
  };

  // 加载数据函数
  const loadData = async () => {
    try {
      const response = await fetchApplications();
      setApplications(response.data || MOCK_APPLICATIONS);

      // 更新看板数据
      const newKanbanData: Record<string, Application[]> = {
        APPLIED: [],
        SCREENING: [],
        REVIEWED: [],
        SHORTLISTED: [],
        INTERVIEWING: [],
        INTERVIEW_PASSED: [],
        OFFERED: [],
        HIRED: [],
        REJECTED: [],
        WITHDRAWN: [],
      };

      (response.data || MOCK_APPLICATIONS).forEach((app: Application) => {
        if (newKanbanData[app.status]) {
          newKanbanData[app.status].push(app);
        }
      });

      setKanbanData(newKanbanData);
    } catch (error) {
      console.error('加载数据失败:', error);
      // 保持使用Mock数据
    }
  };

  // 拖拽开始 - 增强的视觉反馈
  const handleDragStart = (e: React.DragEvent, application: Application) => {
    console.log('🎯 [拖拽开始]', {
      applicationId: application.id,
      candidateName: getCandidateName(application.candidateId),
      currentStatus: application.status,
      clientX: e.clientX,
      clientY: e.clientY
    });

    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('applicationId', application.id);

    // 🔧 同时更新 state 和 ref，确保全局监听器能访问到
    setDraggedApplication(application);
    draggedAppRef.current = application;

    // 记录拖拽位置
    setDragPosition({ x: e.clientX, y: e.clientY });
  };

  // 拖拽经过 - 实时视觉反馈
  const handleDragOver = (e: React.DragEvent, status: string) => {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    setDragOverStatus(status);

    // 更新拖拽位置
    setDragPosition({ x: e.clientX, y: e.clientY });

    console.log('📍 [拖拽经过]', {
      status,
      clientX: e.clientX,
      clientY: e.clientY
    });
  };

  // 拖拽离开 - 移除高亮
  const handleDragLeave = (e: React.DragEvent) => {
    // 只在真正离开列时移除高亮（防止子元素触发）
    const target = e.currentTarget as HTMLElement;
    const rect = target.getBoundingClientRect();
    const { clientX, clientY } = e;

    if (
      clientX < rect.left ||
      clientX > rect.right ||
      clientY < rect.top ||
      clientY > rect.bottom
    ) {
      setDragOverStatus(null);
    }
  };

  // 拖拽放置 - 更新状态
  const handleDrop = async (e: React.DragEvent, newStatus: ApplicationStatus) => {
    e.preventDefault();
    setDragOverStatus(null);

    const applicationId = e.dataTransfer.getData('applicationId');
    console.log('🎯 [拖拽放置]', {
      applicationId,
      newStatus,
      hasToken: !!localStorage.getItem('auth_token')
    });

    if (!applicationId || !draggedApplication) {
      console.log('❌ 拖拽放置失败：缺少applicationId或draggedApplication');
      return;
    }

    // 检查是否已登录
    const token = typeof window !== 'undefined' ? localStorage.getItem('auth_token') : null;
    if (!token) {
      toast.error('❌ 请先登录后再进行操作');
      setDraggedApplication(null);
      setDragPosition(null);
      // 引导用户登录
      setTimeout(() => {
        router.push('/login?redirect=' + encodeURIComponent('/applications?view=kanban'));
      }, 1000);
      return;
    }

    // 如果状态没变化，不做处理
    if (draggedApplication.status === newStatus) {
      setDraggedApplication(null);
      setDragPosition(null);
      return;
    }

    try {
      setUpdatingStatus(applicationId);

      // 调用 API 更新状态
      await updateApplicationStatus(applicationId, newStatus);

      // 更新本地数据 - 优化：使用不可变更新
      setKanbanData((prev) => {
        const updated = { ...prev };
        const oldStatus = draggedApplication.status;

        // 从原状态列移除
        updated[oldStatus] = updated[oldStatus].filter(
          (app) => app.id !== applicationId
        );

        // 添加到新状态列
        updated[newStatus] = [
          ...updated[newStatus],
          { ...draggedApplication, status: newStatus },
        ];

        return updated;
      });

      // 显示成功提示
      toast.success('✅ 状态更新成功');
    } catch (error: any) {
      console.error('更新状态失败:', error);

      // 根据错误类型显示不同的提示
      if (error?.message?.includes('Unauthorized') || error?.message?.includes('401')) {
        toast.error('❌ 登录已过期，请重新登录');
        setTimeout(() => {
          router.push('/login?redirect=' + encodeURIComponent('/applications?view=kanban'));
        }, 1500);
      } else if (error?.message?.includes('无法从') && error?.message?.includes('转换到')) {
        toast.error(`⚠️ ${error.message}`);
      } else {
        toast.error('更新状态失败，请重试');
      }

      // 重新加载数据以恢复正确状态
      loadData();
    } finally {
      setUpdatingStatus(null);
      setDraggedApplication(null);
      setDragPosition(null);
    }
  };

  // 拖拽结束 - 清理状态
  const handleDragEnd = () => {
    console.log('✅ [拖拽结束]');
    setDraggedApplication(null);
    draggedAppRef.current = null; // 🔧 同时清理 ref
    setDragOverStatus(null);
    setDragPosition(null);
  };

  // 列表视图
  const ListView = () => (
    <div className="space-y-4">
      {applications.length === 0 ? (
        <Card>
          <CardContent className="py-12 text-center text-gray-500">
            暂无应聘记录
          </CardContent>
        </Card>
      ) : (
        applications.map((application) => (
          <Card key={application.id} className="hover:shadow-md transition-shadow cursor-pointer" onClick={() => router.push(`/applications/${application.id}`)}>
            <CardContent className="p-6">
              <div className="flex items-start justify-between">
                <div className="flex-1">
                  <div className="flex items-center gap-3 mb-2">
                    <h3 className="text-lg font-semibold">
                      {getCandidateName(application.candidateId)}
                    </h3>
                    <Badge className={ApplicationStatusColors[application.status]}>
                      {ApplicationStatusLabels[application.status]}
                    </Badge>
                  </div>

                  <div className="space-y-1 text-sm text-gray-600">
                    <div className="flex items-center gap-2">
                      <Building2 className="h-4 w-4" />
                      <span>
                        {getCandidateCompany(application.candidateId)} →{' '}
                        {getJobTitle(application.jobId)}
                      </span>
                    </div>
                    {application.candidate?.email && (
                      <div className="flex items-center gap-2">
                        <Mail className="h-4 w-4" />
                        <span>{application.candidate.email}</span>
                      </div>
                    )}
                    {application.candidate?.phoneNumber && (
                      <div className="flex items-center gap-2">
                        <Phone className="h-4 w-4" />
                        <span>{application.candidate.phoneNumber}</span>
                      </div>
                    )}
                    <div className="flex items-center gap-2">
                      <Clock className="h-4 w-4" />
                      <span>
                        {new Date(application.appliedAt).toLocaleDateString('zh-CN')}
                      </span>
                    </div>
                  </div>

                  {application.matchScore && (
                    <div className="mt-3">
                      <Badge variant="outline" className="text-green-600">
                        匹配度: {application.matchScore}%
                      </Badge>
                    </div>
                  )}
                </div>

                <div className="flex items-center gap-2">
                  <Link href={`/applications/${application.id}`}>
                    <Button variant="ghost" size="sm">
                      查看详情
                    </Button>
                  </Link>
                </div>
              </div>
            </CardContent>
          </Card>
        ))
      )}
    </div>
  );

  // 看板视图 - 增强的原生 HTML5 拖拽实现
  const KanbanView = () => (
    <div className="flex gap-4 overflow-x-auto pb-4">
      {KanbanColumns.map((column) => {
        const columnApplications = kanbanData[column.status] || [];

        // 🎯 只显示有数据的列，或者显示所有列（如果没有筛选）
        const hasFilter = searchParams.get('filter') || searchParams.get('status');
        if (hasFilter && columnApplications.length === 0) {
          return null; // 筛选时隐藏空列
        }

        const isDragOver = dragOverStatus === column.status;
        const hasUpdatingCard = columnApplications.some(
          (app) => updatingStatus === app.id
        );

        return (
          <div
            key={column.status}
            data-column-status={column.status}
            onDragOver={(e) => handleDragOver(e, column.status)}
            onDragLeave={handleDragLeave}
            onDrop={(e) => handleDrop(e, column.status as ApplicationStatus)}
            className={`
              flex-shrink-0 w-80 ${column.color} rounded-lg p-4
              transition-all duration-300 ease-out
              ${isDragOver
                ? 'ring-4 ring-blue-400 ring-opacity-60 scale-105 shadow-2xl bg-opacity-80'
                : ''
              }
            `}
          >
            {/* 列标题 */}
            <div className="flex items-center justify-between mb-4">
              <div className="flex items-center gap-2">
                <h3 className="font-semibold text-gray-900">{column.label}</h3>
                {isDragOver && (
                  <span className="text-xs text-blue-600 animate-pulse">放开以放置</span>
                )}
              </div>
              <Badge
                variant="secondary"
                className={isDragOver ? 'animate-bounce' : ''}
              >
                {columnApplications.length}
              </Badge>
            </div>

            {/* 卡片容器 */}
            <div
              className="space-y-3 min-h-[200px]"
              onDragOver={(e) => {
                // 🔧 容器也允许拖拽事件
                e.preventDefault();
                handleDragOver(e, column.status);
              }}
            >
              {columnApplications.map((application) => {
                const isDragging = draggedApplication?.id === application.id;
                const isUpdating = updatingStatus === application.id;

                return (
                  <Card
                    key={application.id}
                    data-application-id={application.id}
                    draggable
                    onDragStart={(e) => handleDragStart(e, application)}
                    onDragEnd={handleDragEnd}
                    onClick={(e) => {
                      // 防止拖拽后触发点击
                      if (!isDragging) {
                        router.push(`/applications/${application.id}`);
                      }
                    }}
                    className={`
                      cursor-grab active:cursor-grabbing
                      transition-all duration-200 ease-out
                      ${isDragging
                        ? 'opacity-40 scale-90 rotate-3 shadow-2xl'
                        : 'hover:shadow-xl hover:scale-[1.03] hover:-translate-y-1'
                      }
                      ${isUpdating ? 'pointer-events-none opacity-50' : ''}
                      ${isDragOver && !isDragging ? 'opacity-80' : ''}
                    `}
                  >
                    <CardContent className="p-4">
                      <div className="flex items-start gap-3">
                        {/* 拖拽手柄 */}
                        <div className="flex-shrink-0 mt-1">
                          <GripVertical className="h-4 w-4 text-gray-400" />
                        </div>

                        {/* 卡片内容 */}
                        <div className="flex-1 min-w-0">
                          <div className="flex items-start justify-between mb-2">
                            <div className="flex-1">
                              <h4 className="font-semibold text-sm text-gray-900 mb-1 truncate">
                                {getCandidateName(application.candidateId)}
                              </h4>
                              <p className="text-xs text-gray-600 truncate">
                                应聘：{getJobTitle(application.jobId)}
                              </p>
                            </div>
                            {isUpdating && (
                              <Loader2 className="h-4 w-4 animate-spin text-blue-500 flex-shrink-0 ml-2" />
                            )}
                          </div>

                          {application.candidate?.currentCompany && (
                            <div className="flex items-center gap-1.5 text-xs text-gray-600 mb-2">
                              <Building2 className="h-3 w-3 flex-shrink-0" />
                              <span className="truncate">{application.candidate.currentCompany}</span>
                            </div>
                          )}

                          {application.matchScore && (
                            <div className="mb-2">
                              <Badge
                                variant="secondary"
                                className="text-xs bg-gradient-to-r from-green-50 to-emerald-50 text-green-700 border-green-200"
                              >
                                匹配度 {application.matchScore}%
                              </Badge>
                            </div>
                          )}

                          <div className="flex items-center gap-1.5 text-xs text-gray-500">
                            <Clock className="h-3 w-3 flex-shrink-0" />
                            <span>
                              {new Date(application.appliedAt).toLocaleDateString('zh-CN')}
                            </span>
                          </div>
                        </div>
                      </div>
                    </CardContent>
                  </Card>
                );
              })}

              {/* 空状态提示 */}
              {columnApplications.length === 0 && (
                <div
                  className={`
                    text-center py-12 rounded-lg border-2 transition-all duration-300
                    ${isDragOver
                      ? 'border-blue-400 bg-blue-50 text-blue-600 scale-105'
                      : 'border-dashed border-gray-300 text-gray-400'
                    }
                  `}
                >
                  {isDragOver ? (
                    <div className="space-y-2">
                      <Inbox className="h-8 w-8 mx-auto text-blue-500 animate-bounce" />
                      <p className="text-sm font-medium">放开以放置</p>
                    </div>
                  ) : (
                    <div className="space-y-2">
                      <Inbox className="h-8 w-8 mx-auto opacity-50" />
                      <p className="text-sm">暂无应聘记录</p>
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  );

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {/* Back button */}
        <BackHeader />

        {/* 页头 */}
        <div className="flex items-center justify-between mb-4">
          <div>
            <h1 className="text-3xl font-bold text-gray-900">应聘管理</h1>
            <p className="mt-2 text-sm text-gray-600">
              {stats ? `共 ${stats.total} 条应聘记录` : '管理候选人应聘流程'}
            </p>
            {viewMode === 'kanban' && (
              <div className="flex items-center gap-4 mt-1">
                <p className="text-sm text-blue-600">
                  💡 提示：拖拽应聘卡片可快速更新状态
                </p>
                <button
                  onClick={() => {
                    console.log('🧪 [测试按钮点击]');
                    console.log('✅ 拖拽状态:', {
                      draggedApp: draggedApplication?.id,
                      dragOverStatus,
                      draggedAppRef: draggedAppRef.current?.id
                    });

                    const cards = document.querySelectorAll('[draggable="true"]');
                    const columns = document.querySelectorAll('[data-column-status]');

                    alert(`测试结果：\n✅ 可拖拽卡片: ${cards.length} 个\n✅ 列容器: ${columns.length} 个\n✅ 当前拖拽应用: ${draggedApplication?.id || '无'}\n✅ Ref中的应用: ${draggedAppRef.current?.id || '无'}`);
                  }}
                  className="text-xs bg-green-100 text-green-700 px-2 py-1 rounded hover:bg-green-200"
                >
                  🧪 测试拖拽状态
                </button>
              </div>
            )}
          </div>
          <Link href="/applications/new">
            <Button className="flex items-center gap-2">
              <Plus className="h-4 w-4" />
              创建应聘记录
            </Button>
          </Link>
        </div>

        {/* 统计卡片 */}
        <div className="mb-6">
          <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
            {/* 总应聘数 */}
            <div className="bg-white rounded-lg shadow p-4 hover:shadow-md transition-all duration-200">
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-2xl font-bold text-gray-900">{stats.total}</div>
                  <div className="text-sm text-gray-600 mt-1">总应聘数</div>
                </div>
                <a
                  href="/applications?filter=all"
                  className="h-10 w-10 rounded-lg bg-blue-100 flex items-center justify-center hover:opacity-70 transition-opacity"
                  style={{ cursor: 'pointer' }}
                >
                  <Users className="h-5 w-5 text-blue-600" />
                </a>
              </div>
            </div>

            {/* 今日新增 */}
            <div className="bg-white rounded-lg shadow p-4 hover:shadow-md transition-all duration-200">
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-2xl font-bold text-gray-900">{stats.todayApplied}</div>
                  <div className="text-sm text-gray-600 mt-1">今日新增</div>
                </div>
                <a
                  href="/applications?filter=today"
                  className="h-10 w-10 rounded-lg bg-green-100 flex items-center justify-center hover:opacity-70 transition-opacity"
                  style={{ cursor: 'pointer' }}
                >
                  <TrendingUp className="h-5 w-5 text-green-600" />
                </a>
              </div>
            </div>

            {/* 面试中 */}
            <div className="bg-white rounded-lg shadow p-4 hover:shadow-md transition-all duration-200">
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-2xl font-bold text-gray-900">{stats.byStatus?.INTERVIEWING || 0}</div>
                  <div className="text-sm text-gray-600 mt-1">面试中</div>
                </div>
                <a
                  href="/applications?status=INTERVIEWING"
                  className="h-10 w-10 rounded-lg bg-yellow-100 flex items-center justify-center hover:opacity-70 transition-opacity"
                  style={{ cursor: 'pointer' }}
                >
                  <Briefcase className="h-5 w-5 text-yellow-600" />
                </a>
              </div>
            </div>

            {/* 录用率 */}
            <div className="bg-white rounded-lg shadow p-4 hover:shadow-md transition-all duration-200">
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-2xl font-bold text-gray-900">
                    {stats.hireRate ? `${stats.hireRate}%` : '-'}
                  </div>
                  <div className="text-sm text-gray-600 mt-1">录用率</div>
                </div>
                {stats.hireRate ? (
                  <a
                    href="/applications?status=HIRED"
                    className="h-10 w-10 rounded-lg bg-purple-100 flex items-center justify-center hover:opacity-70 transition-opacity"
                    style={{ cursor: 'pointer' }}
                  >
                    <TrendingUp className="h-5 w-5 text-purple-600" />
                  </a>
                ) : (
                  <div
                    className="h-10 w-10 rounded-lg bg-purple-100 flex items-center justify-center opacity-50"
                    style={{ cursor: 'not-allowed' }}
                  >
                    <TrendingUp className="h-5 w-5 text-purple-400" />
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>

        {/* 搜索和筛选栏 */}
        <div className="mb-6 space-y-4">
          {/* 搜索框 */}
          <div className="relative">
            <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-gray-400" />
            <input
              type="text"
              placeholder="搜索候选人姓名、邮箱、公司..."
              value={search}
              onChange={(e) => {
                console.log('🔍 [搜索] 输入:', e.target.value);
                handleSearch(e.target.value);
              }}
              className="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 pl-10"
            />
          </div>

          {/* 筛选器 */}
          <div className="flex items-center gap-3 flex-wrap">
            <Filter className="h-4 w-4 text-gray-500" />
            <span className="text-sm text-gray-600">筛选：</span>

            {/* 状态筛选 - 原生HTML select */}
            <select
              value={statusFilter || ''}
              onChange={(e) => {
                console.log('🔄 [状态筛选] 原值:', statusFilter, '→ 新值:', e.target.value || 'all');
                handleStatusFilter(e.target.value || 'all');
              }}
              className="h-10 w-40 rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
            >
              <option value="">所有状态</option>
              {Object.entries(ApplicationStatusLabels).map(([key, label]) => (
                <option key={key} value={key}>
                  {label}
                </option>
              ))}
            </select>

            {/* 职位筛选 - 原生HTML select */}
            {jobs.length > 0 && (
              <select
                value={jobFilter || ''}
                onChange={(e) => {
                  console.log('🔄 [职位筛选] 原值:', jobFilter, '→ 新值:', e.target.value || 'all');
                  handleJobFilter(e.target.value || 'all');
                }}
                className="h-10 w-48 rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
              >
                <option value="">所有职位</option>
                {jobs.map((job) => (
                  <option key={job.id} value={job.id}>
                    {job.title}
                  </option>
                ))}
              </select>
            )}

            {/* 视图切换按钮 */}
            <div className="flex gap-2 ml-auto">
              <Button
                variant={viewMode === 'kanban' ? 'default' : 'outline'}
                size="icon"
                onClick={() => setViewMode('kanban')}
              >
                <LayoutGrid className="h-4 w-4" />
              </Button>
              <Button
                variant={viewMode === 'list' ? 'default' : 'outline'}
                size="icon"
                onClick={() => setViewMode('list')}
              >
                <List className="h-4 w-4" />
              </Button>
            </div>

            {/* 清除筛选 */}
            {hasActiveFilters && (
              <Button
                variant="ghost"
                size="sm"
                onClick={clearFilters}
                className="h-9 px-3"
              >
                清除筛选
              </Button>
            )}
          </div>
        </div>

        {/* 筛选提示 */}
        {(searchParams.get('filter') || searchParams.get('status')) && (
          <div className="mb-6 p-4 bg-blue-50 border border-blue-200 rounded-lg flex items-center justify-between">
            <div className="flex items-center gap-2">
              <Badge variant="default" className="bg-blue-600">
                筛选中
              </Badge>
              <span className="text-sm text-blue-800">
                {searchParams.get('filter') === 'today' && '显示：今日新增（已申请状态）'}
                {searchParams.get('filter') === 'all' && '显示：所有应聘记录'}
                {searchParams.get('status') === 'INTERVIEWING' && '显示：面试中的应聘'}
                {searchParams.get('status') === 'HIRED' && '显示：已录用的应聘'}
              </span>
            </div>
            <Link href="/applications">
              <Button variant="ghost" size="sm" className="text-blue-700 hover:text-blue-900">
                清除筛选
              </Button>
            </Link>
          </div>
        )}

        {/* 内容区域 */}
        <>
          {viewMode === 'list' ? <ListView /> : <KanbanView />}
        </>
      </div>

      {/* 🔍 调试面板 - 临时添加，用于诊断拖拽问题 */}
      <DragDebugPanel />
    </div>
  );
}
