// Hooks
import { useToast } from '@/components/shared/Toast';

// API Functions
import { fetchApplications, updateApplicationStatus } from '@/lib/api';

// Shared Components
import { BackHeader } from '@/components/ui/BackHeader';

// Debug Component (仅用于调试)
import { DragDebugPanel } from '@/components/debug-drag-panel';

// UI Components
import { Button } from '@gametalent/ui';
import { Input } from '@gametalent/ui';
import { Badge } from '@gametalent/ui';
import { Card, CardContent } from '@gametalent/ui';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@gametalent/ui';

// Icons
import {
  Plus,
  Search,
  Filter,
  LayoutGrid,
  List,
  Clock,
  Building2,
  Mail,
  Phone,
  Loader2,
  Users,
  TrendingUp,
  Briefcase,
  Inbox,
  GripVertical,
} from 'lucide-react';

// Types
import {
  Application,
  ApplicationStats,
  ApplicationStatus,
  ApplicationStatusLabels,
  ApplicationStatusColors,
  KanbanColumns,
} from '@/types/application';

type ViewMode = 'list' | 'kanban';

// ============================================
// 🎨 Mock 数据 - 高质量示例数据
// ============================================

const MOCK_STATS: ApplicationStats = {
