# Database
DATABASE_URL="postgresql://gametalent:gametalent_password@localhost:5432/gametalent_os"

# Redis
REDIS_URL="redis://localhost:6379"

# API Configuration
PORT=3001
NODE_ENV=development

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# JWT Authentication
JWT_SECRET="your-secret-key-change-in-production-please"
JWT_EXPIRES_IN="7d"

# AI / Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama2"

# Application
APP_NAME="GameTalent OS"
APP_URL="http://localhost:3000"

# Logging
LOG_LEVEL="debug"

# Email / SMTP Configuration (邮件通知配置)
# SMTP 服务器地址（常见选项：smtp.gmail.com, smtp.qq.com, smtp.aliyun.com）
SMTP_HOST="smtp.gmail.com"
# SMTP 端口（通常 587 用于 TLS，465 用于 SSL）
SMTP_PORT=587
# SMTP 用户名（通常是你的邮箱地址）
SMTP_USER="your-email@gmail.com"
# SMTP 密码（Gmail 需要使用应用专用密码，不是登录密码）
SMTP_PASS="your-app-password"
# 发件人邮箱地址（可选，默认使用 SMTP_USER）
EMAIL_FROM="noreply@gametalent.com"
