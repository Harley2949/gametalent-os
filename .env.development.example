# ============================================
# GameTalent OS - 开发环境配置模板
# ============================================
#
# 使用方法:
#   1. 复制此文件为 .env.development
#   2. 填写所有必需的配置项
#   3. 运行: npm run dev
#
# ⚠️  注意事项:
#   - 不要将此文件提交到 Git
#   - 开发环境可以使用较弱的密钥（方便测试）
#   - 生产环境必须使用强随机密钥

# ============================================
# 应用基础配置
# ============================================
NODE_ENV=development
APP_NAME="GameTalent OS"
APP_URL="http://localhost:3000"
PORT=3006

# ============================================
# 数据库配置
# ============================================
# Docker PostgreSQL
DATABASE_URL="postgresql://gametalent:gametalent_password@127.0.0.1:5432/gametalent_os?schema=public"

# 或使用云数据库（Supabase / Neon / PlanetScale）
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# ============================================
# JWT 认证配置
# ============================================
# 开发环境密钥（至少 32 字符）
JWT_SECRET="dev-secret-key-32-chars-long-change-me"
JWT_EXPIRES_IN="7d"

# ============================================
# 前端配置
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3006"
FRONTEND_URL="http://localhost:3000"

# ============================================
# Redis 配置（可选）
# ============================================
# Docker Redis
REDIS_URL="redis://localhost:6379"

# 或使用云 Redis（Upstash / Redis Cloud）
# REDIS_URL="rediss://default:password@host:6379"

# ============================================
# AI / Ollama 配置
# ============================================
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama2"

# ============================================
# 邮件 / SMTP 配置（可选）
# ============================================
# 开发环境可以使用 mailtrap 进行测试
# SMTP_HOST="sandbox.smtp.mailtrap.io"
# SMTP_PORT=2525
# SMTP_USER="your-mailtrap-username"
# SMTP_PASS="your-mailtrap-password"
# EMAIL_FROM="noreply@gametalent.dev"

# 或使用真实 SMTP（Gmail / QQ 邮箱）
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="noreply@gametalent.com"

# ============================================
# 日志配置
# ============================================
# 开发环境可以使用 debug 级别
LOG_LEVEL="debug"

# ============================================
# 安全配置
# ============================================
# 开发环境可以关闭 CORS 限制
ENABLE_CORS=true
ENABLE_RATE_LIMIT=false

# ============================================
# 文件上传配置
# ============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# ============================================
# 第三方服务配置（可选）
# ============================================
# Sentry 错误追踪
# SENTRY_DSN="https://xxx@sentry.io/xxx"

# AWS S3（用于生产环境文件存储）
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="gametalent-uploads"
