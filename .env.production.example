# ============================================
# GameTalent OS - 生产环境配置模板
# ============================================
#
# ⚠️  重要安全提示:
#   1. 所有密钥必须使用强随机生成（至少 64 字符）
#   2. 不要使用此模板中的示例值
#   3. 使用密钥管理服务存储敏感信息
#   4. 定期轮换密钥（建议每 90 天）
#
# 生成安全密钥:
#   npx ts-node scripts/generate-secrets.ts --all
#
# 推荐密钥管理服务:
#   - AWS Secrets Manager
#   - Google Secret Manager
#   - Azure Key Vault
#   - HashiCorp Vault

# ============================================
# 应用基础配置
# ============================================
NODE_ENV=production
APP_NAME="GameTalent OS"
APP_URL="https://your-domain.com"
PORT=3006

# ============================================
# 数据库配置
# ============================================
# ⚠️  生产环境必须使用强密码
# 格式: postgresql://user:PASSWORD@host:5432/database?schema=public
DATABASE_URL="postgresql://gametalent:CHANGE_ME_STRONG_PASSWORD@prod-db-host:5432/gametalent_os?schema=public&sslmode=require"

# 连接池大小
DATABASE_POOL_SIZE=20

# ============================================
# JWT 认证配置
# ============================================
# ⚠️  生产环境必须使用至少 64 字符的强随机密钥
# 生成方法: npx ts-node scripts/generate-secrets.ts --jwt
JWT_SECRET="CHANGE_ME_USE_STRONG_RANDOM_64_CHAR_SECRET"
JWT_EXPIRES_IN="7d"

# ============================================
# 前端配置
# ============================================
NEXT_PUBLIC_API_URL="https://api.your-domain.com"
FRONTEND_URL="https://your-domain.com"

# ============================================
# Redis 配置（推荐）
# ============================================
# 使用云 Redis 服务（Upstash / Redis Cloud / AWS ElastiCache）
REDIS_URL="rediss://default:CHANGE_ME_PASSWORD@prod-redis-host:6379"

# ============================================
# AI / Ollama 配置
# ============================================
# 生产环境建议使用托管的 LLM API
# OLLAMA_BASE_URL="https://your-ollama-instance.com"
# OLLAMA_MODEL="llama2"

# 或使用 OpenAI / Anthropic / 阿里云等 API
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# ============================================
# 邮件 / SMTP 配置
# ============================================
# ⚠️  生产环境必须配置真实的 SMTP 服务
# 推荐使用: SendGrid / AWS SES / Mailgun / 阿里云邮件
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="SG.CHANGE_ME_YOUR_SENDGRID_API_KEY"
EMAIL_FROM="noreply@your-domain.com"

# ============================================
# 日志配置
# ============================================
# 生产环境使用 info 或 warn 级别
LOG_LEVEL="info"

# ============================================
# 安全配置
# ============================================
ENABLE_CORS=true
ENABLE_RATE_LIMIT=true
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ============================================
# 文件上传配置
# ============================================
# ⚠️  生产环境应该使用对象存储（S3 / OSS）
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# ============================================
# 监控和错误追踪（推荐）
# ============================================
# Sentry - 错误追踪和性能监控
SENTRY_DSN="https://xxx@sentry.io/xxx"

# Datadog - 应用性能监控
# DD_API_KEY="..."
# DD_APP_KEY="..."

# ============================================
# AWS S3 配置（文件存储）
# ============================================
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="gametalent-uploads-prod"

# ============================================
# 其他安全配置
# ============================================
# CORS 允许的域名（逗号分隔）
CORS_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# 会话密钥（用于会话管理）
SESSION_SECRET="CHANGE_ME_USE_STRONG_RANDOM_48_CHAR_SECRET"

# 数据加密密钥（用于敏感数据加密）
ENCRYPTION_KEY="CHANGE_ME_USE_STRONG_RANDOM_64_CHAR_HEX_KEY"

# OAuth 状态密钥（用于 OAuth 集成）
OAUTH_STATE_SECRET="CHANGE_ME_USE_STRONG_RANDOM_32_CHAR_SECRET"

# ============================================
# 备份和恢复
# ============================================
# 数据库备份存储
BACKUP_S3_BUCKET="gametalent-backups-prod"
BACKUP_SCHEDULE="0 2 * * *" # 每天凌晨 2 点

# ============================================
# Webhook 配置
# ============================================
# Slack 通知
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# ============================================
# 功能开关
# ============================================
FEATURE_AI_MATCHING=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_ANALYTICS=true
